# Pattern Stack Environment Configuration
# Project: stack-bench
#
# Copy to .env and fill in values:
#   cp .env.example .env
#   pts env  # or edit manually
#
# For CI/CD, these must also be set as GitHub Actions secrets:
#   GH_PAT                  - GitHub PAT with read access to private deps
#   CLAUDE_CODE_OAUTH_TOKEN - Claude Code OAuth token for AI reviews

# ================================
# GitHub (private dependency access)
# ================================
# PAT with contents:read on pattern-stack/backend-patterns and
# pattern-stack/agentic-patterns. Used by uv to install git deps.
# In CI, set as GH_PAT repo secret.
GH_PAT=

# ================================
# Project
# ================================
PROJECT_NAME=stack-bench
PORT_OFFSET=500

# ================================
# Database (PostgreSQL)
# ================================
# Constructed from DB_* vars below — override if needed
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
SYNC_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_HOST=localhost
DB_PORT=5932
DB_NAME=stack-bench
DB_USER=stack-bench
DB_PASSWORD=password

# ================================
# Redis
# ================================
REDIS_URL=redis://localhost:6879
REDIS_PORT=6879
REDIS_ENABLED=true

# ================================
# MinIO (S3-Compatible Storage)
# ================================
MINIO_PORT=9500
MINIO_CONSOLE_PORT=9501
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_S3_ENDPOINT_URL=http://localhost:9500
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=stack_bench

# ================================
# UI Services (Optional)
# ================================
ADMINER_PORT=9080
REDIS_COMMANDER_PORT=9081

# ================================
# Electric SQL (Real-time sync)
# ================================
ELECTRIC_PORT=3600
ELECTRIC_URL=http://localhost:3600
VITE_ELECTRIC_URL=http://localhost:3600

# ================================
# Application Servers
# ================================
BACKEND_PORT=8500
FRONTEND_PORT=3500
API_HOST=0.0.0.0
API_PORT=8500
VITE_PORT=3500
VITE_API_BASE_URL=http://localhost:8500

# ================================
# CORS
# ================================
CORS_ALLOW_ORIGINS=http://localhost:3500

# ================================
# JWT Authentication
# ================================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
