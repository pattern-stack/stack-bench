# Stack Bench Environment Configuration
#
# Usage:
#   With 1Password:  op run --env-file=.env.example -- pts dev
#   Without:         cp .env.example app/.env  (replace op:// refs with real values)

# ================================
# Database (PostgreSQL)
# ================================
DATABASE_URL=postgresql+asyncpg://stack-bench:password@localhost:5732/stack-bench

# ================================
# Security
# ================================
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# ================================
# GitHub (user token — legacy, will be replaced by per-user OAuth)
# ================================
GITHUB_TOKEN=op://DugsApps/Stack Bench/github_token

# ================================
# GitHub App (Stack Bench, App ID 3169724)
# ================================
GITHUB_APP_ID=3169724
GITHUB_APP_CLIENT_ID=Iv23lixxrPIqZQvr3BlX
GITHUB_APP_CLIENT_SECRET=op://DugsApps/Stack Bench/github_app_client_secret
GITHUB_APP_PRIVATE_KEY=op://DugsApps/Stack Bench/github_app_private_key
