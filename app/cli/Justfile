# Stack Bench CLI

# Build the CLI binary
build:
    go build -o bin/stack-bench .

# Run tests
test:
    go test ./...

# Quality gates
quality:
    go vet ./... && go test ./...

# Run the CLI
run *args:
    go run . {{args}}

# Run in demo mode (prefilled prompts, press enter to advance)
demo *args:
    go run . --demo {{args}}

# Show component gallery (all atoms and molecules, scrollable)
gallery:
    go run . --demo-gallery

# Show every spinner preset animated side-by-side
spinners:
    go run . --demo-spinners

# Run CLI in a tmux session for AI-driven testing
# Usage: just demo-tmux
#   Then from another terminal:
#     tmux send-keys -t sb:cli Enter       # press enter
#     tmux capture-pane -t sb:cli -p       # read screen
demo-tmux *args:
    #!/usr/bin/env bash
    tmux kill-session -t sb 2>/dev/null || true
    tmux new-session -d -s sb -n cli "cd {{justfile_directory()}} && go run . --demo {{args}}"
    echo "CLI running in tmux session 'sb', pane 'sb:cli'"
    echo ""
    echo "Commands:"
    echo "  tmux attach -t sb                    # watch live"
    echo "  tmux send-keys -t sb:cli Enter       # press enter"
    echo "  tmux send-keys -t sb:cli 'hello'     # type text"
    echo "  tmux capture-pane -t sb:cli -p       # read screen"
    echo "  tmux kill-session -t sb              # stop"
