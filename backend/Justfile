# Stack Bench Backend
# Most commands handled by pts (pts dev, pts test, pts quality, pts format, pts lint)

export PYTHONPATH := justfile_directory()

# Run database migrations
migrate:
    uv run alembic upgrade head

# Generate a new migration
migration msg:
    uv run alembic revision --autogenerate -m "{{msg}}"

# Seed the database with SDLC agents
seed:
    pts db seed seeds/agents.yaml
