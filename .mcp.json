{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--browserUrl", "http://127.0.0.1:9222"]
    },
    "lighthouse": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@danielsogl/lighthouse-mcp@latest"]
    }
  }
}
